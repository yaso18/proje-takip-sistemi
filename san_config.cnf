[ req ]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = req_ext
distinguished_name = dn

[ dn ]
C = TR
ST = Istanbul
L = Istanbul
O = Proje Takip
OU = IT Department
CN = yasokral.web.tr  # Ana Alan Adınız

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = yasokral.web.tr  # Kendi domaininiz
DNS.2 = localhost
IP.1 = 127.0.0.1
